{
  "name": "@ikaru5/heimdall-react-state",
  "version": "0.1.0",
  "description": "React bindings and observable store wrapper for heimdall-contract instances.",
  "type": "module",
  "main": "src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "docs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikaru5/heimdall-react-state.git"
  },
  "sideEffects": false,
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules node ./node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*.{js,jsx,json,md}\" --check",
    "format:write": "prettier \"**/*.{js,jsx,json,md}\" --write",
    "build:types": "find src -name '*.d.ts' -delete && tsc -p tsconfig.types.json",
    "prepublishOnly": "npm test && npm run lint && npm run build:types"
  },
  "keywords": [
    "heimdall",
    "contract",
    "react",
    "state",
    "validation"
  ],
  "author": "Kirill Kulikov <k.kulikov94@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@ikaru5/heimdall-contract": "^0.10.0",
    "react": ">=18"
  },
  "devDependencies": {
    "@ikaru5/heimdall-contract": "^0.10.0",
    "@swc/core": "^1.13.5",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.17",
    "cross-env": "^10.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "prettier": "^3.2.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-test-renderer": "^19.1.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "test-exclude": "^7.0.1"
  }
}
